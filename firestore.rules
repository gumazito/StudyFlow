rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function userExists() {
      return isAuth() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function hasRole(role) {
      return isAuth() && userExists() && role in userDoc().roles;
    }
    function isAdmin() {
      return isAuth() && userExists() && 'admin' in userDoc().roles;
    }

    // ── Users ─────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ── Packages (Courses) ────────────────────────────────
    match /packages/{packageId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth() && (
        resource.data.authorId == request.auth.uid || isAdmin()
      );
    }

    // ── Test Results ──────────────────────────────────────
    match /test_results/{resultId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAuth();
    }

    // ── Learner Progress ──────────────────────────────────
    match /learner_progress/{progressId} {
      allow read: if isAuth();
      allow create, update: if isAuth();
      allow delete: if isAuth();
    }

    // ── Gamification ──────────────────────────────────────
    match /gamification/{userId} {
      allow read: if isAuth();
      allow write: if isOwner(userId);
    }

    // ── Spaced Repetition ─────────────────────────────────
    match /spaced_rep/{docId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // ── Social: Follow Requests ───────────────────────────
    match /follow_requests/{requestId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
    }

    // ── Social: Cheers ────────────────────────────────────
    match /cheers/{cheerId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
    }

    // ── Mentor Requests ───────────────────────────────────
    match /mentor_requests/{requestId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
    }

    // ── Groups ────────────────────────────────────────────
    match /groups/{groupId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAdmin();
    }

    // ── Group Join Requests ───────────────────────────────
    match /group_requests/{requestId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
    }

    // ── Feedback ──────────────────────────────────────────
    match /feedback/{feedbackId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
    }

    // ── Ratings ───────────────────────────────────────────
    match /ratings/{ratingId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // ── AI Config ─────────────────────────────────────────
    match /ai_config/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ── Admin Notifications ───────────────────────────────
    match /admin_notifications/{notifId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
    }

    // ── Announcements ─────────────────────────────────────
    match /announcements/{announcementId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
    }

    // ── Cross-Publish ─────────────────────────────────────
    match /cross_publish/{docId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // ── Spotify Tokens ──────────────────────────────────
    match /spotify_tokens/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // ── Push Notification Tokens ────────────────────────
    match /push_tokens/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
    }

    // ── Notification Logs ───────────────────────────────
    match /notification_logs/{logId} {
      allow read: if isAuth();
      allow create: if isAuth();
    }

    // ── Privacy Settings ──────────────────────────────────
    match /privacy_settings/{userId} {
      allow read: if isAuth();
      allow write: if isOwner(userId);
    }

    // ── Listening Status ──────────────────────────────────
    match /listening_status/{userId} {
      allow read: if isAuth();
      allow write: if isOwner(userId);
    }

    // ── Music Shares ──────────────────────────────────────
    match /music_shares/{shareId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // ── Study Plans ──────────────────────────────────────
    match /study_plans/{planId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }
  }
}
