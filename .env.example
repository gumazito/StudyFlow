# ============================================================
# StudyFlow — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# Firebase Configuration (required)
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:abcdef123456

# System Admin Email (auto-granted admin role on signup)
NEXT_PUBLIC_SYSTEM_ADMIN_EMAIL=courtenay@hollis.family

# Base path (leave empty for root, set for subpath hosting e.g. /StudyFlow)
NEXT_PUBLIC_BASE_PATH=

# Environment identifier (development | staging | production)
NEXT_PUBLIC_ENV=development

# Cloud Functions URL (auto-detected if not set)
# NEXT_PUBLIC_FUNCTIONS_URL=https://us-central1-studyflow-app.cloudfunctions.net

# Firebase Cloud Messaging VAPID key (for push notifications)
# Generate at Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
# NEXT_PUBLIC_FIREBASE_VAPID_KEY=your-vapid-key

# ============================================================
# Cloud Functions Config (set via firebase functions:config:set)
# ============================================================
# firebase functions:config:set abr.guid="YOUR_ABR_GUID"
# firebase functions:config:set spotify.client_id="YOUR_SPOTIFY_CLIENT_ID"
# firebase functions:config:set spotify.client_secret="YOUR_SPOTIFY_CLIENT_SECRET"
# firebase functions:config:set spotify.redirect_uri="https://us-central1-studyflow-app.cloudfunctions.net/spotifyCallback"
# firebase functions:config:set openai.api_key="YOUR_OPENAI_KEY" (for TTS)
# firebase functions:config:set elevenlabs.api_key="YOUR_ELEVENLABS_KEY" (alternative TTS)
# firebase functions:config:set sendgrid.api_key="YOUR_SENDGRID_KEY"
# firebase functions:config:set sendgrid.from_email="noreply@studyflow.app"
# firebase functions:config:set twilio.account_sid="YOUR_TWILIO_SID"
# firebase functions:config:set twilio.auth_token="YOUR_TWILIO_AUTH_TOKEN"
# firebase functions:config:set twilio.from_number="+61XXXXXXXXX"
# firebase functions:config:set stripe.secret_key="sk_..."
# firebase functions:config:set stripe.webhook_secret="whsec_..."
# firebase functions:config:set stripe.price_id_monthly="price_..."
# firebase functions:config:set stripe.price_id_yearly="price_..."
# firebase functions:config:set app.url="https://studyflow-app.web.app"
