{
  "name": "studyflow-functions",
  "version": "1.0.0",
  "description": "StudyFlow Firebase Cloud Functions backend",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "18"
  },
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^4.7.0",
    "cors": "^2.8.5",
    "stripe": "^14.0.0",
    "@sendgrid/mail": "^8.0.0",
    "twilio": "^4.20.0",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/node-fetch": "^2.6.11"
  }
}
