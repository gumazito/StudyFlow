# ============================================================
# StudyFlow — Staging Environment Variables
# ============================================================
# Copy to .env.staging.local for staging builds.
# Use a SEPARATE Firebase project for staging to isolate data.
# ============================================================

NEXT_PUBLIC_FIREBASE_API_KEY=staging-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=studyflow-staging.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=studyflow-staging
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=studyflow-staging.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:staging123456

NEXT_PUBLIC_SYSTEM_ADMIN_EMAIL=courtenay@hollis.family
NEXT_PUBLIC_BASE_PATH=
NEXT_PUBLIC_ENV=staging
